#include <bits/stdc++.h>
using namespace std;

int mc(vector<int> &a , vector<int> &temp , int l, int r) {
    if (r-l <= 1) return 0;

    int mid = (l+r)/2;
    int cnt = 0;
    
    cnt += mc(a,temp,l, mid);
    cnt += mc(a,temp,mid, r);

    int i = l; //left pointer
    int j = mid; //right pointer
    int k = l; //temp pointer

    while (i<mid && j<r) {
        if (a[i] <= a[j]) {
            temp[k++] = a[i++];
        } else {
            temp[k++] = a[j++];
            cnt += mid - i;
        }
    }
    
    while (i<mid) temp[k++] = a[i++];
    while (j<r) temp[k++] = a[j++];

    //write back
    for (int i=l; i<r; i++) {
        a[i] = temp[i];
    }

    return cnt;
}

